<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_university_teacher_tree" model="ir.ui.view">
        <field name="name">university.teacher.tree</field>
        <field name="model">university.teacher</field>
        <field name="arch" type="xml">
            <list string="Profesores">
                <field name="name" string="Nombre"/>
                <field name="email" widget="email"/>
                <field name="phone" string="Teléfono"/>
                <field name="salary"
                       string="Sueldo Base"
                       groups="university.group_university_finance"
                       sum="Total Sueldos"/>
            </list>
        </field>
    </record>

    <record id="view_university_teacher_form" model="ir.ui.view">
        <field name="name">university.teacher.form</field>
        <field name="model">university.teacher</field>
        <field name="arch" type="xml">
            <form string="Profesor">
                <sheet>
                    <div class="oe_title">
                        <label for="name" string="Nombre del Profesor"/>
                        <h1>
                            <field name="name" placeholder="Ej: Ing. Juan Pérez"/>
                        </h1>
                    </div>

                    <group>
                        <group string="Contacto">
                            <field name="email" widget="email"/>
                            <field name="phone" widget="phone"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Materias a Cargo" name="academic_info">
                            <field name="subject_ids">
                                <list string="Materias">
                                    <field name="name" string="Materia"/>
                                    <field name="study_plan_id" string="Plan"/>
                                </list>
                            </field>
                        </page>

                        <page string="Información Contable"
                              name="finance_info"
                              groups="university.group_university_finance">
                            <group>
                                <group string="Datos de Pago">
                                    <field name="bank_account" string="CBU / Alias"/>
                                    <field name="salary" string="Sueldo Base"/>
                                </group>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
</odoo>