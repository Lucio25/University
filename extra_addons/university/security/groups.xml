<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="module_category_university" model="ir.module.category">
        <field name="name">Universidad</field>
        <field name="description">Gestión de accesos para el sistema universitario</field>
        <field name="sequence">10</field>
    </record>

    <record id="group_university_academic" model="res.groups">
        <field name="name">Universidad / Área Académica</field>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_university_finance" model="res.groups">
        <field name="name">Universidad / Área de Finanzas</field>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>
</odoo>